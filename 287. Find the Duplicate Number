class Solution {
    public int findDuplicate(int[] nums) {
        int slow = nums[0];          // tortoise starts at first value
        int fast = nums[0];          // hare starts at first value

        do {
            slow = nums[slow];       // move 1 step
            fast = nums[nums[fast]]; // move 2 steps
        } while (slow != fast);      // meeting point inside cycle
        slow = nums[0];              // we can reset slow or fast to start

        while (slow != fast) {
            slow = nums[slow];       // move 1 step
            fast = nums[fast];       // move 1 step
        }

        return slow;                 // entrance of cycle = duplicate we can return slow or fat
    }
}
