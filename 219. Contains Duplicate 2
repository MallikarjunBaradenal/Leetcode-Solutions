class Solution {
    public boolean containsNearbyDuplicate(int[] nums, int k) {

        Set<Integer> window = new HashSet<>(); // stores current sliding window elements

        for (int i = 0; i < nums.length; i++) { // traverse array

            if (window.contains(nums[i])) { // duplicate found within window
                return true;
            }

            window.add(nums[i]); // add current element into window

            if (window.size() > k) { // maintain window size at most k
                window.remove(nums[i - k]); // remove element leaving window
            }
        }

        return false; // no valid duplicate found
    }
}