class Solution {
    public int distinctAverages(int[] nums) {
        Arrays.sort(nums);                 // sort array

        int left = 0;                      // smallest pointer
        int right = nums.length - 1;       // largest pointer

        Set<Integer> set = new HashSet<>();// store unique sums

        while (left < right) {
            set.add(nums[left] + nums[right]); // average uniqueness depends on sum
            left++;                            // move inward
            right--;                           // move inward
        }

        return set.size();                 // count distinct averages
    }
}