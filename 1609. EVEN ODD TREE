/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean isEvenOddTree(TreeNode root) {
        Queue<TreeNode> q = new LinkedList<>(); // BFS queue
        q.offer(root);                          // start from root
        boolean evenLevel = true;               // level 0 is even

        while (!q.isEmpty()) {
            int size = q.size();                // nodes in current level
            int prev = evenLevel ? Integer.MIN_VALUE : Integer.MAX_VALUE;

            for (int i = 0; i < size; i++) {
                TreeNode node = q.poll();
                int val = node.val;

                if (evenLevel) { // even-indexed level
                    if (val % 2 == 0 || val <= prev) return false;
                } else { // odd-indexed level
                    if (val % 2 == 1 || val >= prev) return false;
                }

                prev = val;

                if (node.left != null) q.offer(node.left);
                if (node.right != null) q.offer(node.right);
            }

            evenLevel = !evenLevel; // move to next level
        }

        return true;
    }
}