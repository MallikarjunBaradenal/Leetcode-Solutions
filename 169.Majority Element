class Solution {
    public int majorityElement(int[] nums) {

        int candidate = 0;   // potential majority element
        int count = 0;       // vote count

        for (int num : nums) {      // traverse array

            if (count == 0) {       // choose new candidate
                candidate = num;
            }

            if (num == candidate) { // same candidate gets vote
                count++;
            } else {                // different element cancels vote
                count--;
            }
        }

        return candidate;           // majority element
    }
}