class Solution {
    public int minFallingPathSum(int[][] matrix) {
        int n = matrix.length; // size of matrix

        // Process from second row to last row
        for (int i = 1; i < n; i++) {
            for (int j = 0; j < n; j++) {

                int up = matrix[i - 1][j]; // directly above

                int leftDiag = j > 0 ? matrix[i - 1][j - 1] : Integer.MAX_VALUE; // upper-left

                int rightDiag = j < n - 1 ? matrix[i - 1][j + 1] : Integer.MAX_VALUE; // upper-right

                matrix[i][j] += Math.min(up, Math.min(leftDiag, rightDiag)); // add best previous path
            }
        }

        int ans = Integer.MAX_VALUE; // final answer

        for (int val : matrix[n - 1]) { // minimum in last row
            ans = Math.min(ans, val);
        }

        return ans;
    }
}