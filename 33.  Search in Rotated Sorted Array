class Solution {
    public int search(int[] nums, int target) {

        int left = 0;                     // start of search space
        int right = nums.length - 1;      // end of search space

        while (left <= right) {           // continue until search space is exhausted

            int mid = left + (right - left) / 2; // avoid overflow

            if (nums[mid] == target) {    // target found
                return mid;
            }

            if (nums[left] <= nums[mid]) { // left half is sorted

                if (target >= nums[left] && target < nums[mid]) {
                    right = mid - 1;      // target lies in sorted left half
                } else {
                    left = mid + 1;       // search right half
                }
            } 
            else {                      // right half is sorted

                if (target > nums[mid] && target <= nums[right]) {
                    left = mid + 1;       // target lies in sorted right half
                } else {
                    right = mid - 1;      // search left half
                }
            }
        }

        return -1;                        // target not present
    }
}
