class Solution {
    public String firstPalindrome(String[] words) {
        for (String word : words) {              // check each word from left to right
            if (isPalindrome(word)) {            // if current word is palindrome
                return word;                     // first palindrome found
            }
        }
        return "";                               // no palindrome exists
    }

    private boolean isPalindrome(String s) {
        int left = 0;                            // start pointer
        int right = s.length() - 1;             // end pointer

        while (left < right) {                  // compare both ends
            if (s.charAt(left) != s.charAt(right)) {
                return false;                   // mismatch => not palindrome
            }
            left++;                             // move forward
            right--;                            // move backward
        }

        return true;                            // all characters matched
    }
}