class Solution {
    public int maxProduct(int[] nums) {

        int currMax = nums[0];      // Maximum product ending at current index
        int currMin = nums[0];      // Minimum product ending at current index
        int answer = nums[0];       // Global maximum product

        for (int i = 1; i < nums.length; i++) { // Traverse array

            int num = nums[i];                 // Current element

            if (num < 0) {                     // Negative flips max and min
                int temp = currMax;
                currMax = currMin;
                currMin = temp;
            }

            currMax = Math.max(num, currMax * num); // Best positive product
            currMin = Math.min(num, currMin * num); // Worst negative product

            answer = Math.max(answer, currMax);     // Update answer
        }

        return answer; // Maximum product subarray
    }
}
