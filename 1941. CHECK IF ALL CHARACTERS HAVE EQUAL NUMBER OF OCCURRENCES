class Solution {
    public boolean areOccurrencesEqual(String s) {
        int[] freq = new int[26];

        for (char ch : s.toCharArray()) {
            freq[ch - 'a']++;
        }

        int target = 0;

        for (int count : freq) {
            if (count == 0) continue;

            if (target == 0) {
                target = count;
            } else if (target != count) {
                return false;
            }
        }

        return true;
    }
}