import java.util.Stack;

class Solution {
    public String removeDuplicates(String s) {
        Stack<Character> stack = new Stack<>();
        
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            
            // If stack is not empty and top element matches current char, remove it
            if (!stack.isEmpty() && stack.peek() == ch) {
                stack.pop();
            } else {
                // Otherwise, add the current character to the stack
                stack.push(ch);
            }
        }
        
        // Build the final string from the remaining characters in the stack
        StringBuilder sb = new StringBuilder();
        while (!stack.isEmpty()) {
            sb.append(stack.pop());
        }
        
        // Reverse because stack is Last-In-First-Out (LIFO)
        return sb.reverse().toString();
    }
}
