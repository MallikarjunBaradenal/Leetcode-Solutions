class Solution {

    public void rotate(int[] nums, int k) {

        int n = nums.length;              // Store array length

        k = k % n;                        // Handle cases where k > n

        reverse(nums, 0, n - 1);          // Step 1: Reverse entire array

        reverse(nums, 0, k - 1);          // Step 2: Reverse first k elements

        reverse(nums, k, n - 1);          // Step 3: Reverse remaining elements
    }

    private void reverse(int[] nums, int start, int end) {

        while (start < end) {             // Continue until pointers cross

            int temp = nums[start];       // Save left element temporarily

            nums[start] = nums[end];      // Copy right element to left position

            nums[end] = temp;             // Put saved left element at right position

            start++;                      // Move left pointer one step right

            end--;                        // Move right pointer one step left
        }
    }
}


class Solution {

    public void rotate(int[] nums, int k) {

        int len = nums.length;      // Store the size of the array

        k = k % len;                // Handle cases where k > array length

        int[] result = new int[len]; // Create a temporary array

        // Move each element to its rotated position
        for (int i = 0; i < len; i++) {

            // Calculate new index after rotation
            result[(i + k) % len] = nums[i];

        }

        // Copy rotated elements back into original array
        for (int i = 0; i < len; i++) {

            nums[i] = result[i];    // Replace original values

        }
    }
}
