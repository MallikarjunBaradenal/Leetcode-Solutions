class Solution {
    public int myAtoi(String s) {
        int i = 0;                      // Current index
        int n = s.length();             // Length of string

        while (i < n && s.charAt(i) == ' ') i++; // Skip leading spaces

        int sign = 1;                   // Assume positive
        if (i < n && (s.charAt(i) == '+' || s.charAt(i) == '-')) {
            if (s.charAt(i) == '-') sign = -1;   // Update sign
            i++;                                 // Move past sign
        }

        int result = 0;                 // Parsed number

        while (i < n && Character.isDigit(s.charAt(i))) {
            int digit = s.charAt(i) - '0';       // Current digit

            // Check overflow before adding digit
            if (result > (Integer.MAX_VALUE - digit) / 10) {
                return sign == 1 ? Integer.MAX_VALUE : Integer.MIN_VALUE;
            }

            result = result * 10 + digit;        // Append digit
            i++;
        }

        return result * sign;           // Apply sign
    }
}